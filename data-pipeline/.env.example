# ============================================================
# momanetpopa.ca — Variables d'environnement du data pipeline
# Copie ce fichier en ".env" et remplis les valeurs
# ============================================================

# --- Google APIs (optionnel mais recommandé) ---
# Nécessaire pour : géocodage précis, photos, notes, site web
# Console: https://console.cloud.google.com
# APIs à activer: Geocoding API, Places API
GOOGLE_API_KEY=

# --- Supabase (obligatoire pour l'import) ---
# Trouvé dans : Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# IMPORTANT: utiliser la clé "service_role" (pas "anon") pour les imports
SUPABASE_SERVICE_KEY=
